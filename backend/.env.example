# App mode: development | production
APP_ENV=development

# Security
REQUIRE_AUTH=false
API_BEARER_TOKEN=replace-with-strong-token
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000,http://127.0.0.1:8000
RATE_LIMIT_PER_MINUTE=120

# Reliability
LLM_MAX_RETRIES=2
ENABLE_DEMO_FALLBACKS=true

# AI Providers
OPENAI_API_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
